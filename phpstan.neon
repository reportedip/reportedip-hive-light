includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - reportedip-hive.php
        - includes
        - admin
        - uninstall.php
    bootstrapFiles:
        - ../phpstan-bootstrap.php
        - tests/phpstan-bootstrap.php
    excludePaths:
        - vendor
        - tests/Unit
        - node_modules
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
