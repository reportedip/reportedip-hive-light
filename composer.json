{
	"name": "reportedip/reportedip-hive",
	"description": "Lightweight brute-force login protection for WordPress with optional community-powered IP reputation checks.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Patrick Schlesinger",
			"email": "1@reportedip.de"
		}
	],
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"squizlabs/php_codesniffer": "^3.9",
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"php-parallel-lint/php-parallel-lint": "^1.4"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true,
		"optimize-autoloader": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyse": "phpstan analyse",
		"test": "phpunit --testsuite unit",
		"check-all": [
			"@lint",
			"@analyse",
			"@test"
		],
		"phplint": "parallel-lint --exclude vendor --exclude node_modules ."
	}
}
